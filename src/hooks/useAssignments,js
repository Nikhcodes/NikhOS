import { useState, useEffect, useRef } from 'react'
import { supabase } from '../utils/supabase'
import { DEFAULT_ASSIGNMENTS } from '../utils/storage'

const CACHE_KEY = 'nikhos_assignments'

export function useAssignments(userId) {
  const [assignments, setAssignmentsState] = useState(() => {
    try {
      const cached = localStorage.getItem(CACHE_KEY)
      return cached ? JSON.parse(cached) : DEFAULT_ASSIGNMENTS
    } catch {
      return DEFAULT_ASSIGNMENTS
    }
  })
  const [loading, setLoading] = useState(true)
  const userIdRef = useRef(userId)

  // Keep ref in sync
  useEffect(() => {
    userIdRef.current = userId
  }, [userId])

  // Fetch from Supabase when userId is available
  useEffect(() => {
    if (!userId) return

    supabase
      .from('assignments')
      .select('*')
      .eq('user_id', userId)
      .order('created_at', { ascending: true })
      .then(({ data, error }) => {
        if (error) {
          console.error('Error fetching assignments:', error)
          setLoading(false)
          return
        }
        if (data && data.length > 0) {
          const normalized = data.map((a) => ({
            id: a.id,
            title: a.title,
            dueDate: a.due_date,
            priority: a.priority,
            completed: a.completed,
          }))
          setAssignmentsState(normalized)
          localStorage.setItem(CACHE_KEY, JSON.stringify(normalized))
        }
        setLoading(false)
      })
  }, [userId])

  const setAssignments = async (newAssignments) => {
    const currentUserId = userIdRef.current
    console.log('saving assignments with userId:', currentUserId)

    setAssignmentsState(newAssignments)
    localStorage.setItem(CACHE_KEY, JSON.stringify(newAssignments))

    if (!currentUserId) {
      console.warn('No userId — skipping Supabase sync')
      return
    }

    const { error: deleteError } = await supabase
      .from('assignments')
      .delete()
      .eq('user_id', currentUserId)

    if (deleteError) {
      console.error('Delete error:', deleteError.message)
      return
    }

    if (newAssignments.length === 0) return

    const rows = newAssignments.map((a) => ({
      id: a.id,
      user_id: currentUserId,
      title: a.title,
      due_date: a.dueDate,
      priority: a.priority,
      completed: a.completed,
    }))

    console.log('inserting rows:', rows)

    const { data, error: insertError } = await supabase
      .from('assignments')
      .insert(rows)
      .select()

    if (insertError) {
      console.error('Insert error:', insertError.message, insertError.details)
    } else {
      console.log('Insert success:', data)
    }
  }

  return [assignments, setAssignments, loading]
}